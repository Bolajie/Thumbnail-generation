# ISTV Thumbnail Engine — Environment Variables
# Fill in both keys before running the server.

# Anthropic API Key (Required for Stage 2: Claude translation layer)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Pexels API Key (Required for Stage 3: Background fetch)
PEXELS_API_KEY=your_pexels_api_key_here

# Port for the Node.js backend
PORT=3001
